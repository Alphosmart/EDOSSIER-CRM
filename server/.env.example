# ────────────────────────────────────────────────
#  EDOSSIER CRM — Server Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_also_change_this

# Client URL (for CORS + password reset email links)
CLIENT_URL=http://localhost:5173

# ────────────────────────────────────────────────
#  Email / SMTP (for password reset + reminders)
# ────────────────────────────────────────────────
# For Gmail: use an App Password (not your account password)
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ────────────────────────────────────────────────
#  Optional — Production Process Manager (pm2)
# ────────────────────────────────────────────────
# Start: pm2 start server.js --name edossier-crm
# Auto-restart on crash: pm2 startup
# View logs: pm2 logs edossier-crm
# Restart: pm2 restart edossier-crm
